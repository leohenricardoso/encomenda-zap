# Database — local PostgreSQL (see docker-compose.yml)
DATABASE_URL=postgresql://admin:admin@localhost:5432/encomenda_zap

# Auth — generate with: openssl rand -base64 32  (must be >= 32 chars)
AUTH_SECRET=your_random_secret_here
AUTH_COOKIE_NAME=__session
AUTH_TOKEN_EXPIRY=15m

# Storage — AWS S3
AWS_ACCESS_KEY_ID=your_access_key_id
AWS_SECRET_ACCESS_KEY=your_secret_access_key
AWS_REGION=sa-east-1
AWS_S3_BUCKET=your-bucket-name
